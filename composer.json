{
	"name": "kntnt/kntnt-gpx-blocks",
	"description": "WordPress plugin that registers three Gutenberg blocks for visualising GPX tracks.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Kntnt",
			"email": "thomas@kntnt.com",
			"homepage": "https://www.kntnt.com"
		}
	],
	"require": {
		"php": ">=8.4"
	},
	"require-dev": {
		"pestphp/pest": "^3.0",
		"phpstan/phpstan": "^2.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"brain/monkey": "^2.6",
		"mockery/mockery": "^1.6",
		"wp-coding-standards/wpcs": "^3.0",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"squizlabs/php_codesniffer": "^3.9",
		"php-stubs/wp-cli-stubs": "^2.12"
	},
	"autoload": {
		"psr-4": {
			"Kntnt\\Gpx_Blocks\\": "classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"config": {
		"optimize-autoloader": true,
		"allow-plugins": {
			"pestphp/pest-plugin": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"scripts": {
		"test": "pest",
		"phpstan": "phpstan analyse --configuration=phpstan.neon.dist --memory-limit=512M",
		"phpcs": "phpcs --standard=phpcs.xml.dist"
	},
	"minimum-stability": "stable"
}
