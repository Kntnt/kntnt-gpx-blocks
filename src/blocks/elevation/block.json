{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "kntnt-gpx-blocks/elevation",
	"title": "GPX Elevation",
	"category": "kntnt",
	"description": "Renders a custom-SVG elevation profile for a GPX track with cursor synchronisation to GPX Map.",
	"keywords": [ "gpx", "elevation", "profile", "chart" ],
	"textdomain": "kntnt-gpx-blocks",
	"editorScript": "file:./index.tsx",
	"viewScriptModule": "file:./view.ts",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"usesContext": [ "postId" ],
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"shadow": true,
		"spacing": {
			"padding": true,
			"margin": true
		}
	},
	"attributes": {
		"mapId": {
			"type": "string",
			"default": "auto"
		},
		"aspectRatio": {
			"type": "string",
			"default": "4/1"
		},
		"minHeight": {
			"type": "string",
			"default": "120px"
		},
		"backgroundColor": {
			"type": "string",
			"default": ""
		},
		"axisColor": {
			"type": "string",
			"default": ""
		},
		"axisLabelColor": {
			"type": "string",
			"default": ""
		},
		"lineColor": {
			"type": "string",
			"default": ""
		},
		"cursorColor": {
			"type": "string",
			"default": ""
		},
		"tooltipBackground": {
			"type": "string",
			"default": ""
		},
		"tooltipColor": {
			"type": "string",
			"default": ""
		},
		"axisFontFamily": {
			"type": "string",
			"default": ""
		},
		"axisFontSize": {
			"type": "string",
			"default": ""
		},
		"axisFontWeight": {
			"type": "string",
			"default": ""
		},
		"axisFontStyle": {
			"type": "string",
			"default": ""
		},
		"tooltipFontFamily": {
			"type": "string",
			"default": ""
		},
		"tooltipFontSize": {
			"type": "string",
			"default": ""
		},
		"tooltipFontWeight": {
			"type": "string",
			"default": ""
		},
		"tooltipFontStyle": {
			"type": "string",
			"default": ""
		},
		"__editorBlockSnapshot": {
			"type": "array",
			"default": [],
			"role": "local"
		}
	}
}
