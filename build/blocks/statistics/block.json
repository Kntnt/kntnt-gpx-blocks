{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kntnt-gpx-blocks/statistics",
  "title": "GPX Statistics",
  "category": "kntnt",
  "description": "Renders a server-side HTML summary of GPX track statistics: distance, elevation range, and total ascent/descent.",
  "keywords": [
    "gpx",
    "statistics",
    "distance",
    "elevation"
  ],
  "textdomain": "kntnt-gpx-blocks",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "usesContext": [
    "postId"
  ],
  "attributes": {
    "mapId": {
      "type": "string",
      "default": "auto"
    },
    "headerBackground": {
      "type": "string",
      "default": ""
    },
    "headerColor": {
      "type": "string",
      "default": ""
    },
    "headerFontFamily": {
      "type": "string",
      "default": ""
    },
    "headerFontSize": {
      "type": "string",
      "default": ""
    },
    "headerFontWeight": {
      "type": "string",
      "default": ""
    },
    "headerFontStyle": {
      "type": "string",
      "default": ""
    },
    "valueBackground": {
      "type": "string",
      "default": ""
    },
    "valueColor": {
      "type": "string",
      "default": ""
    },
    "valueFontFamily": {
      "type": "string",
      "default": ""
    },
    "valueFontSize": {
      "type": "string",
      "default": ""
    },
    "valueFontWeight": {
      "type": "string",
      "default": ""
    },
    "valueFontStyle": {
      "type": "string",
      "default": ""
    }
  }
}