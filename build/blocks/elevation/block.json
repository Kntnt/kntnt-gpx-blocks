{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kntnt-gpx-blocks/elevation",
  "title": "GPX Elevation",
  "category": "kntnt",
  "description": "Renders a custom-SVG elevation profile for a GPX track with cursor synchronization to GPX Map.",
  "keywords": [
    "gpx",
    "elevation",
    "profile",
    "chart"
  ],
  "textdomain": "kntnt-gpx-blocks",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "usesContext": [
    "postId"
  ],
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "dimensions": {
      "aspectRatio": true,
      "minHeight": true
    },
    "shadow": true,
    "spacing": {
      "margin": true
    },
    "typography": {
      "fontFamily": true,
      "fontSize": true,
      "fontWeight": true,
      "fontStyle": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textTransform": true,
      "textDecoration": true,
      "defaultControls": {
        "fontFamily": true,
        "fontSize": true,
        "fontAppearance": true
      }
    }
  },
  "attributes": {
    "mapId": {
      "type": "string",
      "default": "auto"
    },
    "axisColor": {
      "type": "string",
      "default": ""
    },
    "axisLabelColor": {
      "type": "string",
      "default": ""
    },
    "lineColor": {
      "type": "string",
      "default": ""
    },
    "cursorColor": {
      "type": "string",
      "default": ""
    },
    "tooltipBackground": {
      "type": "string",
      "default": ""
    },
    "tooltipColor": {
      "type": "string",
      "default": ""
    },
    "__editorBlockSnapshot": {
      "type": "array",
      "default": [],
      "role": "local"
    }
  }
}