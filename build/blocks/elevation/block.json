{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kntnt-gpx-blocks/elevation",
  "title": "GPX Elevation",
  "category": "kntnt",
  "description": "Renders a custom-SVG elevation profile for a GPX track with cursor synchronisation to GPX Map.",
  "keywords": [
    "gpx",
    "elevation",
    "profile",
    "chart"
  ],
  "textdomain": "kntnt-gpx-blocks",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "usesContext": [
    "postId"
  ],
  "attributes": {
    "mapId": {
      "type": "string",
      "default": "auto"
    },
    "aspectRatio": {
      "type": "string",
      "default": "4/1"
    },
    "minHeight": {
      "type": "string",
      "default": "120px"
    }
  }
}