{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kntnt-gpx-blocks/map",
  "title": "GPX Map",
  "category": "kntnt",
  "description": "Renders an interactive Leaflet map of a GPX track with optional waypoint markers and elevation cursor sync.",
  "keywords": [
    "gpx",
    "map",
    "track",
    "leaflet"
  ],
  "textdomain": "kntnt-gpx-blocks",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "render": "file:./render.php",
  "attributes": {
    "attachmentId": {
      "type": "integer",
      "default": 0
    },
    "mapId": {
      "type": "string",
      "default": ""
    },
    "aspectRatio": {
      "type": "string",
      "default": "16/9"
    },
    "minHeight": {
      "type": "string",
      "default": "240px"
    },
    "maxHeight": {
      "type": "string",
      "default": ""
    },
    "showZoomButtons": {
      "type": "boolean",
      "default": true
    },
    "showScale": {
      "type": "boolean",
      "default": true
    },
    "showFullscreen": {
      "type": "boolean",
      "default": false
    },
    "showDownload": {
      "type": "boolean",
      "default": false
    },
    "enableDrag": {
      "type": "boolean",
      "default": true
    },
    "enableScrollWheelZoom": {
      "type": "boolean",
      "default": false
    },
    "enablePinchZoom": {
      "type": "boolean",
      "default": true
    },
    "enableDoubleClickZoom": {
      "type": "boolean",
      "default": true
    },
    "enableBoxZoom": {
      "type": "boolean",
      "default": false
    },
    "enableKeyboard": {
      "type": "boolean",
      "default": true
    }
  }
}