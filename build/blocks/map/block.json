{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "kntnt-gpx-blocks/map",
  "title": "GPX Map",
  "category": "kntnt",
  "description": "Renders an interactive Leaflet map of a GPX track with optional waypoint markers and elevation cursor sync.",
  "keywords": [
    "gpx",
    "map",
    "track",
    "leaflet"
  ],
  "textdomain": "kntnt-gpx-blocks",
  "editorScript": "file:./index.js",
  "viewScriptModule": "file:./view.js",
  "style": "file:./style-index.css",
  "editorStyle": "file:./index.css",
  "viewStyle": "file:./view.css",
  "render": "file:./render.php",
  "supports": {
    "align": [
      "wide",
      "full"
    ],
    "anchor": true,
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "dimensions": {
      "aspectRatio": true,
      "minHeight": true
    },
    "shadow": true,
    "spacing": {
      "margin": true
    }
  },
  "attributes": {
    "attachmentId": {
      "type": "integer",
      "default": 0
    },
    "mapId": {
      "type": "string",
      "default": ""
    },
    "showZoomButtons": {
      "type": "boolean",
      "default": true
    },
    "showScale": {
      "type": "boolean",
      "default": true
    },
    "showFullscreen": {
      "type": "boolean",
      "default": false
    },
    "showDownload": {
      "type": "boolean",
      "default": false
    },
    "enableDrag": {
      "type": "boolean",
      "default": true
    },
    "enablePinchZoom": {
      "type": "boolean",
      "default": true
    },
    "enableDoubleClickZoom": {
      "type": "boolean",
      "default": true
    },
    "enableKeyboard": {
      "type": "boolean",
      "default": true
    },
    "trackColor": {
      "type": "string",
      "default": ""
    },
    "trackCursorColor": {
      "type": "string",
      "default": ""
    },
    "waypointColor": {
      "type": "string",
      "default": ""
    },
    "waypointLabelBackground": {
      "type": "string",
      "default": ""
    },
    "waypointLabelColor": {
      "type": "string",
      "default": ""
    },
    "waypointLabelFontFamily": {
      "type": "string",
      "default": ""
    },
    "waypointLabelFontSize": {
      "type": "string",
      "default": ""
    },
    "waypointLabelFontWeight": {
      "type": "string",
      "default": ""
    },
    "waypointLabelFontStyle": {
      "type": "string",
      "default": ""
    }
  }
}