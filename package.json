{
	"name": "kntnt-gpx-blocks",
	"version": "0.1.4",
	"description": "WordPress plugin that registers three Gutenberg blocks for visualising GPX tracks.",
	"private": true,
	"scripts": {
		"build": "cross-env WP_EXPERIMENTAL_MODULES=true wp-scripts build",
		"start": "cross-env WP_EXPERIMENTAL_MODULES=true wp-scripts start",
		"format": "wp-scripts format",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"packages-update": "wp-scripts packages-update"
	},
	"dependencies": {
		"@wordpress/element": "^6.45.0",
