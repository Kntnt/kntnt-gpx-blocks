{
	"name": "kntnt-gpx-blocks",
	"version": "0.13.2-pl.1",
	"description": "WordPress plugin that registers two Gutenberg blocks plus a Block Bindings source and pattern for visualising GPX tracks.",
	"private": true,
	"scripts": {
		"build": "cross-env WP_EXPERIMENTAL_MODULES=true wp-scripts build",
		"start": "cross-env WP_EXPERIMENTAL_MODULES=true wp-scripts start",
		"format": "wp-scripts format",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"test:js": "wp-scripts test-unit-js --passWithNoTests",
		"packages-update": "wp-scripts packages-update"
	},
	"dependencies": {
		"@wordpress/element": "^6.45.0",
		"leaflet": "^1.9.4",
		"leaflet.fullscreen": "^3.0.2"
	},
	"devDependencies": {
		"@types/leaflet": "^1.9.21",
		"@wordpress/interactivity": "^6.45.0",
		"@wordpress/scripts": "^32.1.0",
		"cross-env": "^7.0.3"
	},
	"overrides": {
		"serialize-javascript": "^7.0.5",
		"webpack-dev-server": "^5.2.3",
		"markdownlint-cli": {
			"minimatch": "^3.1.5"
		}
	}
}
